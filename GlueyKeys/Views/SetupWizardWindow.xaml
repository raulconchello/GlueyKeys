<Window x:Class="GlueyKeys.Views.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GlueyKeys - Setup"
        Height="750" Width="520"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/icon.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Content -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30,20,30,20">

                <TextBlock Text="Welcome! Let's configure your preferences."
                           FontSize="14" Margin="0,0,0,25" Foreground="#444"/>

                <!-- Run at startup -->
                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Run at Windows startup" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Start automatically when you log in to Windows"
                                       Foreground="Gray" FontSize="12" Margin="0,3,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="RunAtStartupCheckBox" Grid.Column="1"
                                  VerticalAlignment="Center" IsChecked="True"/>
                    </Grid>
                </Border>

                <!-- Show notifications -->
                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Show notifications" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Display a notification when keyboard layout changes"
                                       Foreground="Gray" FontSize="12" Margin="0,3,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="ShowNotificationsCheckBox" Grid.Column="1"
                                  VerticalAlignment="Center" IsChecked="True"/>
                    </Grid>
                </Border>

                <!-- Desktop shortcut -->
                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Create desktop shortcut" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Add a shortcut to your desktop"
                                       Foreground="Gray" FontSize="12" Margin="0,3,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="DesktopShortcutCheckBox" Grid.Column="1"
                                  VerticalAlignment="Center" IsChecked="False"/>
                    </Grid>
                </Border>

                <!-- Start menu shortcut -->
                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Create Start menu shortcut" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Add a shortcut to the Windows Start menu"
                                       Foreground="Gray" FontSize="12" Margin="0,3,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="StartMenuShortcutCheckBox" Grid.Column="1"
                                  VerticalAlignment="Center" IsChecked="False"/>
                    </Grid>
                </Border>

                <!-- Info banner -->
                <Border Background="#E7F3FF" BorderBrush="#0078D4" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="What happens next?" FontWeight="SemiBold" FontSize="14" Foreground="#0078D4" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#333" FontSize="12">
                            When you press a key on a new keyboard, a window will automatically appear allowing you to select which layout to use for that keyboard. The app will remember your choice and switch automatically from then on.
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer buttons -->
        <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="0,1,0,0" Background="#F9F9F9" Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Finish Setup" Width="120" Height="35"
                        Click="FinishButton_Click"
                        Background="#0078D4" Foreground="White"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="15,8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>

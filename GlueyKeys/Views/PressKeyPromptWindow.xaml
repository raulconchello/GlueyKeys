<Window x:Class="GlueyKeys.Views.PressKeyPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GlueyKeys"
        Height="180" Width="400"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/icon.ico"
        Topmost="True">
    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Press any key to set up your keyboard"
                       FontSize="18"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
            <TextBlock Text="You'll be able to choose which layout to use for each keyboard"
                       FontSize="12"
                       Foreground="Gray"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>

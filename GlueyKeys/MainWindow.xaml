<Window x:Class="GlueyKeys.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GlueyKeys"
        Height="450" Width="600"
        MinHeight="350" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/icon.ico"
        Closing="Window_Closing">
    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="MinWidth" Value="150"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Options Row -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <CheckBox x:Name="RunAtStartupCheckBox" Content="Run at startup"
                      Checked="RunAtStartupCheckBox_Changed" Unchecked="RunAtStartupCheckBox_Changed"/>
            <CheckBox x:Name="ShowNotificationsCheckBox" Content="Show notifications"
                      Margin="20,5,5,5"
                      Checked="ShowNotificationsCheckBox_Changed" Unchecked="ShowNotificationsCheckBox_Changed"/>
        </StackPanel>

        <!-- Section Header -->
        <TextBlock Grid.Row="1" Text="Connected Keyboards:" FontWeight="SemiBold" Margin="0,5,0,10"/>

        <!-- Keyboards List -->
        <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="KeyboardsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Checked="KeyboardEnabled_Changed"
                                              Unchecked="KeyboardEnabled_Changed"
                                              Tag="{Binding DeviceId}"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DisplayName}"
                                               VerticalAlignment="Center"
                                               Margin="5,0,10,0"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding DeviceId}"/>

                                    <ComboBox Grid.Column="2"
                                              ItemsSource="{Binding AvailableLayouts}"
                                              SelectedValue="{Binding LayoutId, Mode=TwoWay}"
                                              SelectedValuePath="LayoutId"
                                              DisplayMemberPath="DisplayName"
                                              SelectionChanged="LayoutComboBox_SelectionChanged"
                                              Tag="{Binding DeviceId}"
                                              MinWidth="220"/>

                                    <Button Grid.Column="3"
                                            Click="RemoveKeyboard_Click"
                                            Tag="{Binding DeviceId}"
                                            Margin="10,0,0,0"
                                            Padding="8,4"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            ToolTip="Remove keyboard">
                                        <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                              Fill="#FF6B6B"
                                              Width="18" Height="18"
                                              Stretch="Uniform"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Footer with Cancel/Save Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="80" Padding="10,5" Click="CancelButton_Click" Margin="0,0,10,0"/>
            <Button x:Name="SaveButton" Content="Save" Width="80" Padding="10,5" Click="SaveButton_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
